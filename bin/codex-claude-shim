#!/bin/bash
# codex-claude-shim — drop-in replacement for the claude CLI used by ralph_loop.sh
#
# Set CLAUDE_CODE_CMD=codex-claude-shim in .ralphrc (or use ralph --agent codex)
# to route ralph through the OpenAI Codex CLI instead of Claude Code.
#
# This shim:
#   1. Accepts the full claude CLI argv that build_claude_command() emits
#   2. Extracts -p <prompt> and --model <name>; passes model through to codex as-is
#      (for example, gpt-5.5)
#   3. Runs Codex non-interactively with approval policy `never` and the
#      `workspace-write` sandbox (override with CODEX_SANDBOX) via `exec`
#   4. Synthesises a JSON response in ralph's expected flat format so that
#      response_analyzer.sh can parse it
#   5. Handles --version so ralph's validate_claude_command() succeeds

set -uo pipefail

RALPH_DIR="${RALPH_DIR:-.ralph}"

# --version: ralph calls $CLAUDE_CODE_CMD --version at startup
if [[ "${1:-}" == "--version" ]]; then
    codex_ver=$(codex --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "0.0.0")
    echo "codex-claude-shim 1.0.0 (codex $codex_ver)"
    exit 0
fi

# Parse argv emitted by build_claude_command():
#   --model <x>  --output-format json  --allowedTools t1 t2 ...  --resume <id>
#   --append-system-prompt <text>  --effort <x>  -p <prompt>
#
# Only -p and --model matter; everything else is silently consumed.
prompt=""
model=""
argv=("$@")
i=0
in_allowed_tools=false

while [[ $i -lt ${#argv[@]} ]]; do
    arg="${argv[$i]}"
    case "$arg" in
        -p)
            i=$(( i + 1 ))
            prompt="${argv[$i]:-}"
            in_allowed_tools=false
            ;;
        --model)
            i=$(( i + 1 ))
            model="${argv[$i]:-}"
            in_allowed_tools=false
            ;;
        --output-format|--resume|--append-system-prompt|--effort)
            i=$(( i + 1 ))  # skip value
            in_allowed_tools=false
            ;;
        --allowedTools)
            in_allowed_tools=true
            ;;
        --verbose|--include-partial-messages|--continue|--no-continue)
            # Claude-only switches with no value.
            in_allowed_tools=false
            ;;
        -*)
            # Unknown Claude-only switch. Ignore the switch itself; treating the
            # following argv entry as a value could accidentally consume `-p`.
            in_allowed_tools=false
            ;;
        *)
            if [[ "$in_allowed_tools" != "true" ]]; then
                in_allowed_tools=false
            fi
            ;;
    esac
    i=$(( i + 1 ))
done

if [[ -z "$prompt" ]]; then
    echo '{"result":"codex-claude-shim: no -p prompt provided","is_error":true}' >&2
    exit 1
fi

# Build codex invocation
# Precedence: --model flag from argv > CODEX_MODEL env var
effective_model="${model:-${CODEX_MODEL:-}}"

codex_sandbox="${CODEX_SANDBOX:-workspace-write}"
case "$codex_sandbox" in
    read-only|workspace-write|danger-full-access) ;;
    *)
        echo "codex-claude-shim: invalid CODEX_SANDBOX '$codex_sandbox'" >&2
        exit 1
        ;;
esac

codex_args=(codex --ask-for-approval never --sandbox "$codex_sandbox" exec)

if [[ -n "$effective_model" ]]; then
    codex_args+=(--model "$effective_model")
fi

codex_args+=("$prompt")

# Run Codex with its complete output in a file. Keep response text out of argv
# and environment variables: long agent runs can exceed the platform's ARG_MAX
# limit if their output is expanded into a later command invocation.
tmp_out=""
result_file=""
cleanup() {
    [[ -n "$tmp_out" ]] && rm -f -- "$tmp_out"
    [[ -n "$result_file" ]] && rm -f -- "$result_file"
}
trap cleanup EXIT

if ! tmp_out=$(mktemp); then
    echo "codex-claude-shim: failed to create Codex output file" >&2
    exit 1
fi
"${codex_args[@]}" > "$tmp_out" 2>&1
exit_code=$?

# Prefer the last complete status block emitted by Codex. The prompt itself may
# contain an example block, so only accept blocks with one concrete status and
# boolean exit signal. Fall back to fix_plan.md for agents that emit no block.
explicit_status=$(
    awk '
        /^---RALPH_STATUS---[[:space:]]*$/ { in_block=1; status=""; exit_signal=""; next }
        in_block && /^STATUS:[[:space:]]*/ {
            value=$0; sub(/^STATUS:[[:space:]]*/, "", value)
            if (value ~ /^(COMPLETE|IN_PROGRESS|BLOCKED)$/) status=value
        }
        in_block && /^EXIT_SIGNAL:[[:space:]]*/ {
            value=$0; sub(/^EXIT_SIGNAL:[[:space:]]*/, "", value)
            if (value ~ /^(true|false)$/) exit_signal=value
        }
        in_block && /^---END_RALPH_STATUS---[[:space:]]*$/ {
            if (status != "" && exit_signal != "") print status "\t" exit_signal
            in_block=0
        }
    ' "$tmp_out" | tail -n 1
)

remaining=0
if [[ -f "$RALPH_DIR/fix_plan.md" ]]; then
    remaining=$(grep -c '^\- \[ \]' "$RALPH_DIR/fix_plan.md" 2>/dev/null || true)
    remaining="${remaining:-0}"
fi

if [[ -n "$explicit_status" ]]; then
    status=${explicit_status%%$'\t'*}
    exit_signal=${explicit_status#*$'\t'}
elif [[ "$exit_code" -eq 0 && "$remaining" -eq 0 ]]; then
    status="COMPLETE"
    exit_signal="true"
else
    status="IN_PROGRESS"
    exit_signal="false"
fi

# Synthesise files_modified from git diff since last commit
files_modified=$(git diff --name-only HEAD 2>/dev/null | wc -l | tr -d ' ')

is_error="false"
if [[ "$exit_code" -ne 0 || "$status" == "BLOCKED" ]]; then
    is_error="true"
fi

# Compose the result in a second file so the original Codex bytes, including
# trailing newlines, remain intact. The RALPH_STATUS block inside `result` is
# parsed for EXIT_SIGNAL.
if ! result_file=$(mktemp); then
    echo "codex-claude-shim: failed to create response file" >&2
    exit 1
fi
if ! cp -- "$tmp_out" "$result_file" || \
   ! printf '\n\n---RALPH_STATUS---\nSTATUS: %s\nEXIT_SIGNAL: %s\n---END_RALPH_STATUS---' \
       "$status" "$exit_signal" >> "$result_file"; then
    echo "codex-claude-shim: failed to compose Codex response" >&2
    exit 1
fi

# Let jq read the response from disk rather than argv. This preserves all text
# without imposing the OS argument-size limit.
jq -cn \
    --rawfile result "$result_file" \
    --argjson is_error "$is_error" \
    --argjson files_modified "$files_modified" \
    --argjson exit_signal "$exit_signal" \
    '{result: $result, is_error: $is_error, files_modified: $files_modified, exit_signal: $exit_signal}'
encode_code=$?

if [[ "$encode_code" -ne 0 ]]; then
    echo "codex-claude-shim: failed to encode Codex response as JSON" >&2
    exit "$encode_code"
fi

if [[ "$status" == "BLOCKED" && "$exit_code" -eq 0 ]]; then
    exit 2
fi

exit "$exit_code"
