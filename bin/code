#!/bin/bash
# HITL aider launcher — drops into an interactive aider session with harness defaults
HARNESS_DIR="${HARNESS_DIR:-$HOME/agent-harness}"
AIDER_CONF="$HARNESS_DIR/config/aider.conf.yml"

aider_args=(aider)
[[ -f "$AIDER_CONF" ]] && aider_args+=(--config "$AIDER_CONF")

exec "${aider_args[@]}" "$@"
