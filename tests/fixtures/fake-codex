#!/bin/bash

if [[ "${1:-}" == "--version" ]]; then
    echo "codex-cli 0.144.2"
    exit 0
fi

: "${FAKE_CODEX_ARGV:?FAKE_CODEX_ARGV must name the argv capture file}"
printf '%s\0' "$@" > "$FAKE_CODEX_ARGV"

if [[ -n "${FAKE_CODEX_STDOUT_FILE:-}" ]]; then
    command cat "$FAKE_CODEX_STDOUT_FILE"
fi

exit "${FAKE_CODEX_EXIT_CODE:-0}"
